{
  "name": "wire-lang-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Text-first electronic schematics rendered to SVG. Monorepo root.",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build:js": "pnpm -r run build:js",
    "build": "tsc -b && pnpm -r run build:js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "bench": "node tools/symbol-bench/server.mjs",
    "clean": "tsc -b --clean && rimraf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
