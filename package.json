{
  "name": "wire-lang-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Text-first electronic schematics rendered to SVG. Monorepo root.",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build:js": "pnpm -r run build:js",
    "build": "tsc -b && pnpm -r run build:js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "docs:check": "prettier --check \".github/**/*.yml\" \".github/*.md\" \"README.md\" \"CHANGELOG.md\" \"docs/EXAMPLES.md\" \"docs/brand/README.md\" \"packages/*/README.md\"",
    "docs:format": "prettier --write \".github/**/*.yml\" \".github/*.md\" \"README.md\" \"CHANGELOG.md\" \"docs/EXAMPLES.md\" \"docs/brand/README.md\" \"packages/*/README.md\"",
    "skill:check": "skills add ./skills/wire-lang --list",
    "skill:publish": "skills add eduardozf/wire-lang --skill wire-lang --agent codex --global --copy --yes",
    "pack:dry-run": "pnpm --filter @wire-lang/core pack --dry-run && pnpm --filter @wire-lang/cli pack --dry-run && pnpm --filter wire-lang pack --dry-run",
    "package:smoke": "node scripts/package-smoke-test.mjs",
    "release:check": "pnpm lint && pnpm docs:check && pnpm typecheck && pnpm test && pnpm build && pnpm audit --prod && pnpm pack:dry-run && pnpm package:smoke",
    "examples:update": "node scripts/update-examples.mjs",
    "bench": "node tools/symbol-bench/server.mjs",
    "clean": "tsc -b --clean && rimraf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.0.1",
    "prettier": "3.9.4",
    "rimraf": "^6.0.1",
    "skills": "1.5.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
