{
  "name": "wire-lang-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Text-first electronic schematics rendered to SVG. Monorepo root.",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build:js": "pnpm -r run build:js",
    "build": "tsc -b && pnpm -r run build:js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "docs:check": "prettier --check \".github/**/*.yml\" \".github/PULL_REQUEST_TEMPLATE.md\" \"README.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \"SECURITY_REVIEW.md\" \"CODE_OF_CONDUCT.md\" \"SUPPORT.md\" \"CHANGELOG.md\" \"docs/EXAMPLES.md\" \"docs/OPEN_SOURCE_RELEASE.md\" \"docs/brand/README.md\" \"packages/*/README.md\"",
    "docs:format": "prettier --write \".github/**/*.yml\" \".github/PULL_REQUEST_TEMPLATE.md\" \"README.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \"SECURITY_REVIEW.md\" \"CODE_OF_CONDUCT.md\" \"SUPPORT.md\" \"CHANGELOG.md\" \"docs/EXAMPLES.md\" \"docs/OPEN_SOURCE_RELEASE.md\" \"docs/brand/README.md\" \"packages/*/README.md\"",
    "pack:dry-run": "pnpm --filter @wire-lang/core pack --dry-run && pnpm --filter @wire-lang/cli pack --dry-run && pnpm --filter wire-lang pack --dry-run",
    "package:smoke": "node scripts/package-smoke-test.mjs",
    "release:check": "pnpm lint && pnpm docs:check && pnpm typecheck && pnpm test && pnpm build && pnpm audit --prod && pnpm pack:dry-run && pnpm package:smoke",
    "bench": "node tools/symbol-bench/server.mjs",
    "clean": "tsc -b --clean && rimraf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.9.3",
    "prettier": "3.8.4",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
