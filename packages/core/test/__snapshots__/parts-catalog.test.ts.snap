<g class="wire-component" data-wire-kind="component" data-wire-id="RV1" data-wire-type="Potentiometer" data-wire-symbol="potentiometer" id="wire-component-RV1"><path class="wire-symbol" fill="none" d="M 36 86 L 50 86 L 53 79 L 59 93 L 65 79 L 71 93 L 77 79 L 83 93 L 86 86 L 100 86"/><path class="wire-symbol" fill="none" d="M 68 62 L 68 73.5"/><polygon class="wire-symbol-fill" points="68,77 65.8,73.5 70.2,73.5"/><text class="wire-label" x="68" y="56" text-anchor="middle">RV1</text><text class="wire-label" x="68" y="43" text-anchor="middle">10k</text></g><g class="wire-component" data-wire-kind="component" data-wire-id="RH1" data-wire-type="Rheostat" data-wire-symbol="rheostat" id="wire-component-RH1"><path class="wire-symbol" fill="none" d="M 152 86 L 166 86 L 169 79 L 175 93 L 181 79 L 187 93 L 193 79 L 199 93 L 202 86 L 216 86"/><path class="wire-symbol" fill="none" d="M 172 99 L 193.63 75.57"/><polygon class="wire-symbol-fill" points="196,73 195.24,77.06 192.01,74.08"/><text class="wire-label" x="184" y="69" text-anchor="middle">RH1</text><text class="wire-label" x="184" y="56" text-anchor="middle">4k7</text></g><g class="wire-component" data-wire-kind="component" data-wire-id="D1" data-wire-type="ZenerDiode" data-wire-symbol="zener-diode" id="wire-component-D1"><path class="wire-symbol" fill="none" d="M 268 86 L 293 86"/><path class="wire-symbol" fill="none" d="M 307 86 L 332 86"/><polygon class="wire-symbol-fill" points="293,78 293,94 307,86" fill="#1f2937"/><path class="wire-symbol" fill="none" d="M 303 78 L 307 78 L 307 94 L 311 94"/><text class="wire-label" x="300" y="69" text-anchor="middle">D1</text></g><g class="wire-component" data-wire-kind="component" data-wire-id="D2" data-wire-type="SchottkyDiode" data-wire-symbol="schottky-diode" id="wire-component-D2"><path class="wire-symbol" fill="none" d="M 384 86 L 409 86"/><path class="wire-symbol" fill="none" d="M 423 86 L 448 86"/><polygon class="wire-symbol-fill" points="409,78 409,94 423,86" fill="#1f2937"/